<!DOCTYPE html>
<html lang="zh-Hant">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>個人資料中心</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 30px;
      background-color: #f9f9f9;
    }

    .profile-card {
      width: 480px;
      border: 1px solid #ddd;
      padding: 25px;
      border-radius: 8px;
      box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);
      margin-bottom: 20px;
      background-color: #fff;
    }

    .info-group {
      margin-bottom: 15px;
      font-size: 16px;
      display: flex;
      align-items: center;
    }

    .label {
      font-weight: bold;
      color: #555;
      width: 100px;
      display: inline-block;
    }

    /* 編輯模式下的輸入框（預設隱藏） */
    .edit-input {
      display: none;
      padding: 5px 8px;
      font-size: 14px;
      border: 1px solid #ccc;
      border-radius: 4px;
      width: 220px;
      box-sizing: border-box;
    }

    .edit-radio-group {
      display: none;
    }

    /* 按鈕樣式 */
    .btn-group {
      margin-top: 20px;
    }

    .btn {
      padding: 8px 16px;
      text-decoration: none;
      border-radius: 5px;
      font-weight: bold;
      cursor: pointer;
      border: none;
      font-size: 14px;
      margin-right: 8px;
    }

    .btn-edit {
      background-color: #007bff;
      color: white;
    }

    .btn-save {
      background-color: #28a745;
      color: white;
      display: none;
    }

    .btn-cancel {
      background-color: #6c757d;
      color: white;
      display: none;
    }

    .btn-logout {
      background-color: #6c757d;
      color: white;
      display: inline-block;
      margin-top: 10px;
    }

    .btn-logout:hover {
      background-color: #5a6268;
    }

    /* 管理員專屬樣式 */
    .admin-box {
      width: 480px;
      border: 2px dashed #de1212;
      padding: 20px;
      border-radius: 8px;
      background-color: #fff3f3;
      margin-top: 20px;
      box-sizing: border-box;
    }

    .btn-admin {
      display: inline-block;
      background-color: #de1212;
      color: white;
      padding: 10px 15px;
      text-decoration: none;
      border-radius: 5px;
      font-weight: bold;
    }
  </style>
</head>

<body>
  <h2>歡迎回來，<%= user.username %>！</h2>

  <form id="profileForm" onsubmit="saveProfile(event)">
    <div class="profile-card">
      <h3>基本帳戶與體質資料</h3>

      <div class="info-group">
        <span class="label">電子郵件:</span>
        <span>
          <%= user.email %>
        </span>
      </div>
      <div class="info-group">
        <span class="label">帳戶權限:</span>
        <span>
          <%= user.role==='admin' ? '系統管理員' : '一般會員' %>
        </span>
      </div>

      <div class="info-group">
        <span class="label">年齡:</span>
        <span class="view-text">
          <%= user.age %> 歲
        </span>
        <input type="number" id="edit-age" class="edit-input" min="18" max="100" value="<%= user.age %>" required>
      </div>

      <div class="info-group">
        <span class="label">性別:</span>
        <span class="view-text">
          <%= user.gender %>
        </span>
        <div class="edit-radio-group" id="edit-gender-group">
          <input type="radio" name="gender" value="男" <%=user.gender==='男' ? 'checked' : '' %>> 男
          <input type="radio" name="gender" value="女" <%=user.gender==='女' ? 'checked' : '' %>> 女
        </div>
      </div>

      <div class="info-group">
        <span class="label">身高 (cm):</span>
        <span class="view-text">
          <%= user.height %> cm
        </span>
        <input type="number" id="edit-height" class="edit-input" step="0.1" min="130" max="200"
          value="<%= user.height %>" required>
      </div>

      <div class="info-group">
        <span class="label">體重 (kg):</span>
        <span class="view-text">
          <%= user.weight %> kg
        </span>
        <input type="number" id="edit-weight" class="edit-input" step="0.1" min="20" max="300"
          value="<%= user.weight %>" required>
      </div>

      <div class="info-group">
        <span class="label">聯絡電話:</span>
        <span class="view-text">
          <%= user.phone %>
        </span>
        <input type="tel" id="edit-phone" class="edit-input" pattern="^[2356789]\d{7}$" title="請輸入正確的 8 位數香港電話號碼"
          value="<%= user.phone %>" required>
      </div>

      <div class="btn-group">
        <button type="button" class="btn btn-edit" id="btn-edit" onclick="startEdit()">編輯資料</button>
        <button type="submit" class="btn btn-save" id="btn-save">儲存</button>
        <button type="button" class="btn btn-cancel" id="btn-cancel" onclick="cancelEdit()">取消</button>
      </div>
    </div>
  </form>

  <% if (user.role==='admin' ) { %>
    <div class="admin-box">
      <h3>🛡️ 管理員工具</h3>
      <p>您可以查看並修改系統中所有用戶的資料。</p>
      <a href="/admin/users" class="btn-admin">進入用戶管理後台</a>
    </div>
    <% } %>

      <div>
        <a href="/login/logout" class="btn-logout">安全登出</a>
      </div>

      <script>
        // 切換到編輯模式
        function startEdit() {
          document.querySelectorAll('.view-text').forEach(el => el.style.display = 'none');
          document.querySelectorAll('.edit-input').forEach(el => el.style.display = 'inline-block');
          document.getElementById('edit-gender-group').style.display = 'inline-block';

          document.getElementById('btn-edit').style.display = 'none';
          document.getElementById('btn-save').style.display = 'inline-block';
          document.getElementById('btn-cancel').style.display = 'inline-block';
        }

        // 取消編輯模式（並還原原本的欄位內容）
        function cancelEdit() {
          document.querySelectorAll('.view-text').forEach(el => el.style.display = 'inline');
          document.querySelectorAll('.edit-input').forEach(el => el.style.display = 'none');
          document.getElementById('edit-gender-group').style.display = 'none';

          document.getElementById('btn-edit').style.display = 'inline-block';
          document.getElementById('btn-save').style.display = 'none';
          document.getElementById('btn-cancel').style.display = 'none';

          // 重設表單值為初始狀態
          document.getElementById('profileForm').reset();
        }

        // 儲存資料（透過 Fetch 傳給後端）
        async function saveProfile(event) {
          event.preventDefault(); // 防止傳統表單整頁刷新

          const selectedGender = document.querySelector('input[name="gender"]:checked').value;

          const updatedData = {
            age: document.getElementById('edit-age').value,
            gender: selectedGender,
            height: document.getElementById('edit-height').value,
            weight: document.getElementById('edit-weight').value,
            phone: document.getElementById('edit-phone').value
          };

          try {
            // 送出 POST 到本路由的 /update 
            const response = await fetch('/userInfo/update', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(updatedData)
            });

            const result = await response.json();

            if (result.success) {
              alert('個人資料更新成功！');
              // 重新整理頁面，載入更新後的最新資料
              window.location.reload();
            } else {
              alert('更新失敗：' + result.message);
            }
          } catch (err) {
            console.error(err);
            alert('網路或伺服器錯誤，請稍後再試。');
          }
        }

        // 專治各家瀏覽器「按上一頁」看到舊資料的神仙程式碼
        window.addEventListener('pageshow', function (event) {
          const perfEntries = window.performance && window.performance.getEntriesByType ? window.performance.getEntriesByType('navigation') : [];
          const isBackForward = perfEntries.length > 0 && perfEntries[0].type === 'back_forward';
          if (isBackForward || event.persisted) {
            window.location.reload();
          }
        });
      </script>
</body>

</html>