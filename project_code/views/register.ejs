<!DOCTYPE html>
<html lang="zh-Hant">

<head>
  <meta charset="UTF-8">
  <title>用戶註冊</title>
</head>

<body>
  <a href="/">回到主頁</a>
  <h2>帳號註冊</h2>

  <form id="registerForm">
    <div>
      <label>用戶名:</label>
      <input type="text" name="username" minlength="3" maxlength="15" required>
    </div>
    <div>
      <label>Email:</label>
      <input type="email" name="email" required>
    </div>
    <div>
      <label>密碼:</label>
      <input type="password" name="password" minlength="8" pattern="(?=.*[a-z])(?=.*[A-Z]).{8,}"
        title="密碼長度至少 8 個字元，且必須包含英文大寫與小寫字母" required>
      <small style="color: #666; display: block; margin-top: 4px;">
        (密碼長度至少 8 個字元，且必須包含英文大寫與小寫字母)
      </small>
    </div>
    <div>
      <label>確認密碼:</label>
      <input type="password" name="confirmPassword" minlength="8" pattern="(?=.*[a-z])(?=.*[A-Z]).{8,}"
        title="密碼長度至少 8 個字元，且必須包含英文大寫與小寫字母" required>
    </div>

    <hr>
    <h3>基本體質資料</h3>

    <div>
      <label>年齡:</label>
      <input type="number" name="age" min="18" max="100" required>
      <small style="color: #666;">(限制 18 至 100 歲)</small>
    </div>
    <div>
      <label>性別:</label>
      <input type="radio" name="gender" value="男" checked> 男
      <input type="radio" name="gender" value="女"> 女
    </div>
    <div>
      <label>身高 (cm):</label>
      <input type="number" name="height" step="0.1" min="130" max="200" required>
    </div>
    <div>
      <label>體重 (kg):</label>
      <input type="number" name="weight" step="0.1" min="20" max="300" required>
    </div>
    <div>
      <label>電話:</label>
      <input type="tel" name="phone" pattern="^[2356789]\d{7}$" title="請輸入正確的 8 位數香港電話號碼" required>
      <small style="color: #666;">(香港 8 位數字電話)</small>
    </div>

    <div>
      <label>真實姓名:</label>
      <input type="text" name="realname" minlength="2" maxlength="4" required>
    </div>
    <br>

    <div id="messageBox" style="display: none; padding: 10px; border-radius: 4px; margin-bottom: 15px; width: 280px;">
    </div>

    <button type="submit">註冊</button>
  </form>

  <script>
    document.getElementById('registerForm').addEventListener('submit', async function (e) {
      e.preventDefault(); // 🛑 核心：阻止表單預設的重新整理行為

      const msgBox = document.getElementById('messageBox');
      msgBox.style.display = 'none'; // 每次送出前先隱藏提示框

      // 自動將表單資料打包成物件
      const formData = new FormData(this);
      const data = Object.fromEntries(formData.entries());

      try {
        // 發送非同步 FETCH 請求
        const response = await fetch('/register', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(data) // 轉為 JSON 字串
        });

        const result = await response.json();

        if (response.ok && result.success) {
          // 註冊成功
          msgBox.style.styleUrl = ''; // 清除舊樣式
          msgBox.style.color = 'green';
          msgBox.style.backgroundColor = '#d4edda';
          msgBox.style.border = '1px solid #c3e6cb';
          msgBox.innerText = '🎉 ' + result.message;
          msgBox.style.display = 'block';

          // 延遲 1.5 秒後跳轉到登入頁，讓使用者看得到成功訊息
          setTimeout(() => {
            window.location.href = '/login';
          }, 1500);

        } else {
          // 後端驗證失敗 (例如：用戶名已存在、密碼不夠強...)
          msgBox.style.color = 'red';
          msgBox.style.backgroundColor = '#f8d7da';
          msgBox.style.border = '1px solid #f5c6cb';
          msgBox.innerText = '⚠️ ' + (result.message || '註冊失敗');
          msgBox.style.display = 'block';
        }

      } catch (error) {
        console.error('Error:', error);
        msgBox.style.color = 'red';
        msgBox.style.backgroundColor = '#f8d7da';
        msgBox.style.border = '1px solid #f5c6cb';
        msgBox.innerText = '⚠️ 網路或伺服器連線失敗，請稍後再試。';
        msgBox.style.display = 'block';
      }
    });
  </script>
</body>

</html>