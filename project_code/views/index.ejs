<!DOCTYPE html>
<html>

<head>
  <title>首頁</title>
  <link rel='stylesheet' href='/stylesheets/style.css' />
</head>

<body>
  <% if (locals.successMessage) { %>
    <div
      style="color: #155724; background-color: #d4edda; border: 1px solid #c3e6cb; padding: 10px; border-radius: 4px; margin-bottom: 15px; width: 280px;">
      <%= successMessage %>
    </div>
    <% } %>

      <% if (locals.errorMessage) { %>
        <script>
          // 當頁面載入時，直接彈出後端傳過來的錯誤訊息
          alert("<%= errorMessage %>");
        </script>
        <% } %>
          This is index
</body>

</html>