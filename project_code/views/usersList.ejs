<!DOCTYPE html>
<html lang="zh-Hant">

<head>
  <meta charset="UTF-8">
  <title>管理員後台 - 用戶清單</title>
  <style>
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
    }

    th,
    td {
      border: 1px solid #ddd;
      padding: 8px;
      text-align: left;
    }

    th {
      background-color: #f2f2f2;
    }
  </style>
</head>

<body>
  <h2>🛡️ 系統管理員 - 所有用戶清單</h2>
  <a href="/userInfo">返回我的個人資料</a>

  <table>
    <thead>
      <tr>
        <th>用戶名</th>
        <th>Email</th>
        <th>權限角色</th>
        <th>聯絡電話</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(function(u) { %>
        <tr>
          <td>
            <%= u.username %>
          </td>
          <td>
            <%= u.email %>
          </td>
          <td>
            <%= u.role %>
          </td>
          <td>
            <%= u.phone %>
          </td>
        </tr>
        <% }); %>
    </tbody>
  </table>
  <script>
    // 專治各家瀏覽器「按上一頁」看到舊資料的神仙程式碼
    window.addEventListener('pageshow', function (event) {
      const perfEntries = window.performance && window.performance.getEntriesByType ? window.performance.getEntriesByType('navigation') : [];
      const isBackForward = perfEntries.length > 0 && perfEntries[0].type === 'back_forward';

      // 如果是按上一頁進來的，或者頁面是從瀏覽器快取（persisted）恢復的
      if (isBackForward || event.persisted) {
        // 強制整頁重新向後端要求，這時沒 Token 就會立刻被中間件踢去 /login
        window.location.reload();
      }
    });
  </script>
</body>

</html>