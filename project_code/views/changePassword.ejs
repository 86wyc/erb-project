<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <title>修改密碼</title>
</head>
<body>
    <h2>修改帳戶密碼</h2>

    <% if (locals.errorMessage) { %>
        <div style="color: red; margin-bottom: 15px;">
            ⚠️ <%= errorMessage %>
        </div>
    <% } %>

    <form action="/changePassword" method="POST">
     <label>帳號 (用戶名 或 Email):</label>
        <input type="text" name="account" required>
    </div>
    <div>
        <label>舊密碼:</label>
        <input type="password" name="oldPassword" required>
    </div>
    <div>
        <label>新密碼:</label>
        <input type="password" name="newPassword" 
               minlength="8" 
               pattern="(?=.*[a-z])(?=.*[A-Z]).{8,}" 
               title="密碼長度至少 8 個字元，且必須包含英文大寫與小寫字母" 
               required>
        <small style="color: #666; display: block;">(至少 8 碼，包含英文大小寫)</small>
    </div>
    
    <div style="margin-top: 10px;">
        <label>確認新密碼:</label>
        <input type="password" name="confirmPassword" required>
    </div>
    
    <br>
    <button type="submit">確認修改</button>
    <a href="/login">返回登入</a>
</form>
</body>
</html>